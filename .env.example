# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_DEEPSEEK_API_KEY=
VITE_CEREBRAS_API_KEY=
VITE_BACKEND_URL=
VITE_GROQ_API_KEY_1=
VITE_GROQ_API_KEY_2=
VITE_GROQ_API_KEY_3=
VITE_GROQ_API_KEY_4=
VITE_GROQ_API_KEY_5=

VITE_OPENAI_API_KEY_1=
VITE_OPENAI_API_KEY_2=
VITE_OPENAI_API_KEY_3=
VITE_OPENAI_API_KEY_4=
VITE_OPENAI_API_KEY_5=

VITE_ANTHROPIC_API_KEY_1=
VITE_ANTHROPIC_API_KEY_2=
VITE_ANTHROPIC_API_KEY_3=
VITE_ANTHROPIC_API_KEY_4=
VITE_ANTHROPIC_API_KEY_5=

VITE_GEMINI_API_KEY_2=
VITE_GEMINI_API_KEY_3=
VITE_GEMINI_API_KEY_4=
VITE_GEMINI_API_KEY_5=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
